# ============================================================
# HRMS AI — example env file. Copy to `.env` for local dev.
# Real secrets belong in `.env`, never here.
# ============================================================

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Postgres (provided by the Spring Boot services; see docker-compose for a dev shortcut) ---
# The AI service uses THREE databases, all owned by their respective microservices:
#   hiremind_candidate (candidate-service)  — read/write the AI columns + caches
#   hiremind_company   (company-service)    — read/write the AI columns + caches
#   hiremind_users     (users-service)      — read-only, optional
CANDIDATE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hiremind_candidate
COMPANY_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hiremind_company
USERS_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hiremind_users
PGVECTOR_DIM=768

# --- Redis / Celery ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- LLM ---
# Pick one: mock | grok | groq
#   mock = deterministic fake parser, no key needed (great for dev)
#   grok = xAI Grok (https://console.x.ai)        — keys start with `xai-`
#   groq = Groq LPU inference (https://console.groq.com) — keys start with `gsk_`
LLM_BACKEND=mock
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Grok (xAI)
GROK_API_KEY=
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# Groq (LPU)
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# --- GitHub cross-check (optional) ---
# Personal access token raises rate limit from 60/hr to 5000/hr.
# Create at https://github.com/settings/tokens (no scopes needed for public profile reads).
GITHUB_TOKEN=
GITHUB_TIMEOUT_SECONDS=10

# --- OCR ---
OCR_ENGINE=tesseract

# --- Vector store ---
VECTOR_STORE_BACKEND=pgvector
PINECONE_API_KEY=
PINECONE_INDEX=

# --- Artifacts (uploaded resumes, model files) ---
ARTIFACTS_DIR=./artifacts

# --- ML ---
MODEL_REGISTRY_PATH=./artifacts/models
MODEL_VERSION=v1

# --- Frontend (Next.js test harness) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
